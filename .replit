modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd kvant-site-dev/Import-Launch && pnpm install --no-frozen-lockfile --prefer-offline && cd artifacts/kvant-site && pnpm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd kvant-site-dev/Import-Launch/artifacts/kvant-site && pnpm run start"]
build = ["bash", "-c", "cd kvant-site-dev/Import-Launch/artifacts/kvant-site && pnpm run build"]

[userenv]

[userenv.shared]

[userenv.development]
FRONTEND_URL = "https://ea9ca581-63ae-4b94-ae0d-5c52f2d7440e-00-1id0fw0mrzove.riker.replit.dev"
