modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd kvant-site-dev/Import-Launch && pnpm install --no-frozen-lockfile --prefer-offline && cd artifacts/kvant-site && pnpm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd kvant-bot && pnpm install --no-frozen-lockfile --prefer-offline && PORT=8099 NODE_ENV=development node_modules/.bin/tsx server/index.ts"
waitForPort = 8099

[[workflows.workflow]]
name = "kvant-site-dev/Import-Launch/artifacts/api-server: API Server"
author = "agent"
mode = "parallel"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./kvant-site-dev/Import-Launch/artifacts/api-server"
waitForPort = 8080

[workflows.workflow.tasks.env]
PORT = "8080"

[[workflows.workflow]]
name = "kvant-site-dev/Import-Launch/artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./kvant-site-dev/Import-Launch/artifacts/mockup-sandbox"
waitForPort = 8081

[workflows.workflow.tasks.env]
PORT = "8081"
BASE_PATH = "/__mockup"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Excalidraw Board"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LiveKit Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow]]
name = "Excalidraw Board"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd kvant-board && pnpm install --no-frozen-lockfile --prefer-offline && PORT=8000 NODE_ENV=development node_modules/.bin/tsx server/index.ts"
waitForPort = 8000

[[workflows.workflow]]
name = "LiveKit Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "kvant-video/start.sh"
waitForPort = 9000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8099
externalPort = 8099

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd kvant-site-dev/Import-Launch/artifacts/kvant-site && pnpm run start"]
build = ["bash", "-c", "cd kvant-site-dev/Import-Launch/artifacts/kvant-site && pnpm run build"]

[userenv]

[userenv.shared]
LIVEKIT_API_KEY = "APIE489774A8A86034D"
LIVEKIT_API_SECRET = "e27ffd8d0268aa8c9f9ef04e2c2e3f7e7b9c69a9f78d2fe979370c073a06f6bb"
LIVEKIT_INTERNAL_URL = "http://localhost:9000"

[userenv.development]
FRONTEND_URL = "https://ea9ca581-63ae-4b94-ae0d-5c52f2d7440e-00-1id0fw0mrzove.riker.replit.dev"
